PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=admin_assist_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5500,https://precious-chirwa.github.io

# ─── Frontend URL (used in verification email links) ─────────────────────────
PUBLIC_APP_URL=http://localhost:5500

# ─── Brevo Transactional Email ────────────────────────────────────────────────
BREVO_API_KEY=replace-with-your-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Admin Assist

# ─── Google OAuth (Sprint 2) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
